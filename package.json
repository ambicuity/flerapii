{
  "name": "flerapii",
  "displayName": "Flerapii",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Manage New API-compatible relay accounts: view balances, auto check-ins, export keys, validate APIs, and sync channels.",
  "author": "Ritesh Rana <contact@riteshrana.engineer>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ambicuity/flerapii.git"
  },
  "bugs": {
    "url": "https://github.com/ambicuity/flerapii/issues"
  },
  "homepage": "https://ambicuity.github.io/flerapii/",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:mobile:firefox": "node scripts/android-dev.js",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:all": "pnpm run build && pnpm run build:firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:all": "pnpm run zip && pnpm run zip:firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "test:ci": "vitest --run --coverage",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix",
      "vitest related --run"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@lobehub/icons": "^2.38.0",
    "@plasmohq/storage": "^1.15.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "ai": "^6.0.116",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^0.2.1",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "framer-motion": "^12.37.0",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "lodash-es": "^4.17.23",
    "lucide-react": "^0.577.0",
    "postcss": "^8.5.8",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-countup": "^6.5.3",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.5.8",
    "react-tooltip": "^5.30.0",
    "react-virtuoso": "^4.18.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@playwright/test": "1.58.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "0.1.38",
    "@types/firefox-webext-browser": "^120.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "20.11.5",
